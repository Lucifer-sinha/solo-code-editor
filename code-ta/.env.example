# API Configuration
# Leave empty to use relative URLs (recommended for most setups)
VITE_API_URL=
VITE_WS_URL=

# Examples for different deployment scenarios:

# For localhost development (default behavior):
# VITE_API_URL=http://localhost:5000
# VITE_WS_URL=ws://localhost:5000

# For public domain with backend on different port:
# VITE_API_URL=https://yourdomain.com:5000
# VITE_WS_URL=wss://yourdomain.com:5000

# For public domain with backend proxied through same domain:
# VITE_API_URL=https://yourdomain.com
# VITE_WS_URL=wss://yourdomain.com

# For tunnel services (ngrok, cloudflare, etc.):
# VITE_API_URL=https://your-tunnel-url.ngrok.io
# VITE_WS_URL=wss://your-tunnel-url.ngrok.io